# ============================================================
# 3DGS Modular — .gitignore
# ============================================================

# --- Secrets & certificates ---
.env
env-deploy/
env-local/
nginx/certs/

# --- 3D / ML data files ---
*.ply
*.splat
*.obj
*.ckpt
*.pt
*.pth
*.jpg
*.jpeg
*.png

# --- Video files ---
*.mp4
*.mov
*.avi
frontend/public/*.mp4
frontend/public/*.mov
frontend/public/*.avi

# --- COLMAP ---
*.db
sparse/
dense/

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
build/
dist/

# --- Node ---
node_modules/
.next/
frontend/.next/

# --- Docker volumes ---
pgdata/
miniodata/
redisdata/
rabbitmqdata/

# --- Logs ---
*.log
wandb/
runs/
tensorboard/

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- 기타 ---
input/
output/
datasets/
checkpoints/
